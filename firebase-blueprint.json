{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and roles.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The user's unique ID." },
        "full_name": { "type": "string", "description": "The user's full name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "role": { "type": "string", "enum": ["admin", "staff", "viewer"], "description": "The user's role in the shop." },
        "created_at": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["id", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Stores product details and inventory levels.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The product's unique ID." },
        "sku": { "type": "string", "description": "Stock Keeping Unit." },
        "name": { "type": "string", "description": "Product name." },
        "brand": { "type": "string", "description": "Product brand." },
        "category": { "type": "string", "description": "Product category." },
        "size_variant": { "type": "string", "description": "Size or variant." },
        "barcode": { "type": "string", "description": "Product barcode." },
        "mrp": { "type": "number", "description": "Maximum Retail Price." },
        "cost_price": { "type": "number", "description": "Cost price." },
        "current_stock": { "type": "number", "description": "Current stock quantity." },
        "reorder_level": { "type": "number", "description": "Stock level to trigger reorder alert." },
        "hsn_code": { "type": "string", "description": "HSN code for GST." },
        "tax_rate": { "type": "number", "description": "GST tax rate percentage." },
        "unit": { "type": "string", "description": "Measurement unit (e.g., pcs, kg)." },
        "supplier_name": { "type": "string", "description": "Supplier name." },
        "image_url": { "type": "string", "format": "uri", "description": "Product image URL." },
        "is_active": { "type": "boolean", "description": "Whether the product is active." },
        "created_at": { "type": "string", "format": "date-time", "description": "When the product was added." },
        "updated_at": { "type": "string", "format": "date-time", "description": "When the product was last updated." }
      },
      "required": ["sku", "name", "mrp", "cost_price", "current_stock", "tax_rate"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "Stores billing information.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The invoice's unique ID." },
        "invoice_number": { "type": "string", "description": "Auto-incremented invoice number." },
        "invoice_date": { "type": "string", "format": "date-time", "description": "Date of the invoice." },
        "customer_name": { "type": "string", "description": "Customer name." },
        "customer_phone": { "type": "string", "description": "Customer phone number." },
        "customer_gstin": { "type": "string", "description": "Customer GSTIN." },
        "subtotal": { "type": "number", "description": "Total amount before tax." },
        "total_tax": { "type": "number", "description": "Total GST amount." },
        "discount": { "type": "number", "description": "Total discount applied." },
        "grand_total": { "type": "number", "description": "Final amount to be paid." },
        "payment_method": { "type": "string", "enum": ["cash", "card", "upi"], "description": "Payment method used." },
        "amount_tendered": { "type": "number", "description": "Amount paid by customer." },
        "created_by": { "type": "string", "description": "ID of the user who created the invoice." },
        "created_at": { "type": "string", "format": "date-time", "description": "When the invoice was created." }
      },
      "required": ["invoice_number", "invoice_date", "subtotal", "total_tax", "grand_total", "payment_method"]
    },
    "InvoiceItem": {
      "title": "Invoice Item",
      "description": "Stores individual items within an invoice.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The item's unique ID." },
        "invoice_id": { "type": "string", "description": "The ID of the parent invoice." },
        "product_id": { "type": "string", "description": "The ID of the product." },
        "product_name": { "type": "string", "description": "Product name at the time of sale." },
        "quantity": { "type": "number", "description": "Quantity sold." },
        "unit_price": { "type": "number", "description": "Price per unit at the time of sale." },
        "tax_rate": { "type": "number", "description": "Tax rate applied." },
        "tax_amount": { "type": "number", "description": "Total tax for this item." },
        "total": { "type": "number", "description": "Total amount for this item." }
      },
      "required": ["invoice_id", "product_id", "product_name", "quantity", "unit_price", "tax_rate", "total"]
    }
  },
  "firestore": {
    "/user_profiles/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product inventory documents."
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Billing invoice documents."
    },
    "/invoices/{invoiceId}/items/{itemId}": {
      "schema": "InvoiceItem",
      "description": "Items within an invoice."
    }
  }
}
