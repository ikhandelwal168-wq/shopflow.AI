rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: user_profiles
    // Fields: id, full_name, email, role, created_at
    //
    // Collection: products
    // Fields: id, sku, name, brand, category, mrp, cost_price, current_stock, reorder_level, tax_rate, unit, is_active, created_at, updated_at
    //
    // Collection: invoices
    // Fields: id, invoice_number, invoice_date, customer_name, grand_total, payment_method, created_by, created_at
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ikhandelwal168@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'role']) &&
             data.email is string &&
             data.role in ['admin', 'staff', 'viewer'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['sku', 'name', 'mrp', 'cost_price', 'current_stock']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.mrp is number && data.mrp >= 0 &&
             data.cost_price is number && data.cost_price >= 0 &&
             data.current_stock is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /user_profiles/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /invoices/{invoiceId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();

      match /items/{itemId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if isAdmin();
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
